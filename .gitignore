# ============================================================
# Aurora Care AI / Tech Challenge Fase 4
# Keep in Git: source code, docs, tests, infra, frontend source.
# Keep out of Git: datasets, generated media, model weights,
# local environments, caches, build outputs, and large artifacts.
# ============================================================

# ----------------------------
# Python / virtual environments
# ----------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

.venv/
venv/
env/
ENV/

